students = []

# Number of students
n = int(input())

# Read name and grade
for _ in range(n):
    name = input()
    grade = float(input())
    students.append([name, grade])

# Get sorted unique grades
grades = sorted({student[1] for student in students})

# Second lowest grade
second_lowest = grades[1]

# Get names with the second lowest grade
result = sorted(
    student[0] for student in students if student[1] == second_lowest
)

# Print names
for name in result:
    print(name)
